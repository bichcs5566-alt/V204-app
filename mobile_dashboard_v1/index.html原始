<!doctype html>
<html lang="zh-Hant">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width,initial-scale=1,viewport-fit=cover" />
  <title>v265 每日操作介面</title>
  <style>
    :root{
      --bg:#f4f0e8;
      --card:#ffffff;
      --text:#101828;
      --muted:#667085;
      --line:#e4e7ec;
      --navy:#24385f;
      --green:#e3f8e6;
      --greenText:#087443;
      --orange:#fff0d5;
      --orangeText:#b54708;
      --yellow:#fff7cc;
      --yellowText:#8a6d00;
      --gray:#f2f4f7;
      --grayText:#667085;
      --red:#fee4e2;
      --redText:#b42318;
    }

    *{box-sizing:border-box}

    body{
      margin:0;
      background:var(--bg);
      color:var(--text);
      font-family:-apple-system,BlinkMacSystemFont,"Noto Sans TC","PingFang TC",Arial,sans-serif;
      padding:16px 12px 48px;
    }

    .wrap{
      max-width:820px;
      margin:0 auto;
    }

    .card{
      background:var(--card);
      border-radius:26px;
      padding:20px;
      margin:16px 0;
      box-shadow:0 4px 18px rgba(16,24,40,.06);
    }

    .topbar{
      display:flex;
      gap:12px;
      align-items:center;
      justify-content:space-between;
      margin-bottom:14px;
    }

    h1{
      font-size:30px;
      line-height:1.15;
      margin:0;
      font-weight:900;
      letter-spacing:-.5px;
    }

    h2{
      font-size:24px;
      margin:0 0 14px;
      font-weight:900;
    }

    .btn-row{
      display:grid;
      grid-template-columns:1fr 1fr;
      gap:10px;
      margin-top:14px;
    }

    button{
      border:0;
      background:var(--navy);
      color:white;
      border-radius:18px;
      padding:14px 12px;
      font-size:16px;
      font-weight:900;
      cursor:pointer;
    }

    #syncBanner{
      margin-top:12px;
      font-weight:800;
      color:#2f7d32;
    }

    .meta-grid{
      display:grid;
      grid-template-columns:1fr 1fr;
      gap:10px;
      margin-top:14px;
    }

    .meta-item,.stat-box{
      border:1px solid var(--line);
      background:#f8fafc;
      border-radius:16px;
      padding:12px;
      min-height:66px;
    }

    .meta-item span,.stat-box span{
      display:block;
      color:var(--muted);
      font-size:13px;
      margin-bottom:6px;
      font-weight:800;
    }

    .meta-item b,.stat-box b{
      display:block;
      font-size:17px;
      font-weight:900;
      word-break:break-word;
    }

    .hero{
      color:var(--text);
    }

    .hero-buy{
      background:linear-gradient(135deg,#ffffff 0%,#e8fff0 100%);
      border:2px solid #abefc6;
    }

    .hero-test{
      background:linear-gradient(135deg,#ffffff 0%,#fff3df 100%);
      border:2px solid #fedf89;
    }

    .hero-watch{
      background:linear-gradient(135deg,#ffffff 0%,#fffbe6 100%);
      border:2px solid #fef08a;
    }

    .hero-label{
      color:var(--muted);
      font-size:15px;
      font-weight:900;
    }

    .hero-main{
      margin-top:8px;
      font-size:48px;
      font-weight:1000;
      letter-spacing:-1px;
    }

    .hero-sub{
      color:#475467;
      font-size:17px;
      line-height:1.45;
      margin-top:4px;
    }

    .hero-stats{
      display:grid;
      grid-template-columns:repeat(3,1fr);
      gap:10px;
      margin-top:18px;
    }

    .hero-stats div{
      background:rgba(255,255,255,.72);
      border:1px solid var(--line);
      border-radius:16px;
      padding:12px;
      text-align:center;
    }

    .hero-stats b{
      display:block;
      font-size:26px;
      font-weight:1000;
    }

    .hero-stats span{
      display:block;
      color:var(--muted);
      font-weight:800;
      margin-top:4px;
    }

    .trade-card{
      border:1px solid var(--line);
      border-radius:22px;
      padding:16px;
      margin:12px 0;
      background:#fff;
    }

    .trade-card.buy{border-color:#abefc6;background:#fbfffc}
    .trade-card.test{border-color:#fedf89;background:#fffdf8}
    .trade-card.watch{border-color:#fef08a;background:#fffef8}
    .trade-card.none,.trade-card.skip{background:#f9fafb}

    .trade-top{
      display:grid;
      grid-template-columns:92px 1fr 72px;
      align-items:center;
      gap:10px;
    }

    .badge{
      display:inline-flex;
      align-items:center;
      justify-content:center;
      border-radius:999px;
      padding:9px 12px;
      min-width:72px;
      font-size:16px;
      font-weight:1000;
      white-space:nowrap;
    }

    .badge.buy{background:var(--green);color:var(--greenText)}
    .badge.test{background:var(--orange);color:var(--orangeText)}
    .badge.watch{background:var(--yellow);color:var(--yellowText)}
    .badge.none,.badge.skip{background:var(--gray);color:var(--grayText)}

    .stock{
      font-size:28px;
      font-weight:1000;
      letter-spacing:.5px;
    }

    .score{
      font-size:24px;
      font-weight:1000;
      text-align:right;
    }

    .trade-grid{
      display:grid;
      grid-template-columns:1fr 1fr;
      gap:10px;
      margin-top:14px;
    }

    .trade-grid div{
      background:#f8fafc;
      border:1px solid var(--line);
      border-radius:16px;
      padding:12px;
    }

    .trade-grid span{
      display:block;
      color:var(--muted);
      font-size:13px;
      font-weight:900;
      margin-bottom:6px;
    }

    .trade-grid b{
      font-size:18px;
      font-weight:1000;
    }

    .sub{
      color:#475467;
      font-size:16px;
      font-weight:800;
      margin-top:12px;
    }

    .note{
      color:#344054;
      font-size:16px;
      line-height:1.55;
      margin-top:8px;
      word-break:break-word;
    }

    .debug-grid{
      display:grid;
      grid-template-columns:1fr 1fr;
      gap:10px;
    }

    .candidate-list{
      border-top:1px solid var(--line);
    }

    .candidate-row{
      display:grid;
      grid-template-columns:1fr 90px 86px;
      align-items:center;
      gap:10px;
      padding:14px 0;
      border-bottom:1px solid var(--line);
    }

    .candidate-stock{
      font-size:20px;
      font-weight:1000;
    }

    .candidate-score{
      font-size:18px;
      font-weight:1000;
      text-align:right;
    }

    .summary-grid{
      display:grid;
      grid-template-columns:1fr 1fr 1fr;
      gap:10px;
    }

    .empty{
      background:#f8fafc;
      border:1px solid var(--line);
      border-radius:18px;
      padding:20px;
      color:var(--muted);
      font-size:17px;
      font-weight:800;
      text-align:center;
    }

    .empty.small{
      padding:14px;
      font-size:15px;
    }

    details{
      margin-top:16px;
    }

    summary{
      cursor:pointer;
      font-weight:900;
      color:#344054;
      padding:12px 0;
    }

    .config-grid{
      display:grid;
      gap:10px;
      margin-top:12px;
    }

    input{
      width:100%;
      border:1px solid #d0d5dd;
      border-radius:16px;
      padding:14px 14px;
      font-size:16px;
      background:#fff;
    }

    .config-actions{
      display:grid;
      grid-template-columns:1fr 1fr;
      gap:10px;
      margin-top:10px;
    }

    .btn-light{
      background:#eef2ff;
      color:#24385f;
    }

    @media(max-width:560px){
      body{padding:12px 10px 38px}
      .card{padding:18px;margin:14px 0;border-radius:24px}
      h1{font-size:28px}
      h2{font-size:23px}
      .meta-grid,.debug-grid{grid-template-columns:1fr}
      .hero-main{font-size:44px}
      .trade-top{grid-template-columns:86px 1fr 62px}
      .stock{font-size:26px}
      .score{font-size:22px}
      .summary-grid{grid-template-columns:1fr}
    }
  </style>
</head>
<body>
  <main class="wrap">
    <section class="card">
      <div class="topbar">
        <h1>📊 每日操作介面</h1>
      </div>

      <div class="btn-row">
        <button id="refreshBtn">🔄 重新整理</button>
        <button id="updateBtn">🚀 更新資料</button>
      </div>

      <div id="syncBanner">等待同步</div>

      <div class="meta-grid">
        <div class="meta-item"><span>來源版本</span><b id="sourceName">--</b></div>
        <div class="meta-item"><span>資料狀態</span><b id="dataState">--</b></div>
        <div class="meta-item"><span>訊號日</span><b id="signalDate">--</b></div>
        <div class="meta-item"><span>交易日</span><b id="tradeDate">--</b></div>
        <div class="meta-item"><span>最後更新</span><b id="generatedAt">--</b></div>
        <div class="meta-item"><span>名單數</span><b id="tradeCount">--</b></div>
      </div>

      <details>
        <summary>🔐 GitHub 本機設定</summary>
        <div class="config-grid">
          <input id="ghOwner" placeholder="owner，例如 bichcs5566-alt" />
          <input id="ghRepo" placeholder="repo，例如 V204-app" />
          <input id="ghBranch" placeholder="branch，例如 main" />
          <input id="ghToken" placeholder="token，只存在本機瀏覽器" type="password" />
        </div>
        <div class="config-actions">
          <button id="saveConfigBtn">儲存</button>
          <button id="clearConfigBtn" class="btn-light">清除</button>
        </div>
        <div id="configStatus" class="sub">未儲存</div>
      </details>
    </section>

    <section id="heroCard" class="card hero hero-watch"></section>

    <section class="card">
      <h2>📌 今日操作</h2>
      <div id="tradePlanList"></div>
    </section>

    <section class="card">
      <h2>🧪 篩選狀態</h2>
      <div id="debugGrid" class="debug-grid"></div>
    </section>

    <section class="card">
      <h2>📈 績效摘要</h2>
      <div class="summary-grid">
        <div class="stat-box"><span>Return</span><b id="returnVal">--</b></div>
        <div class="stat-box"><span>MDD</span><b id="mddVal">--</b></div>
        <div class="stat-box"><span>Sharpe</span><b id="sharpeVal">--</b></div>
      </div>
    </section>

    <section id="coreList" class="card"></section>
    <section id="alphaList" class="card"></section>
  </main>

  <script src="./app.js"></script>
</body>
</html>
